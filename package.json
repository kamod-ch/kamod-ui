{
  "name": "kamod-ui",
  "description": "Lightweight UI components for Preact and Tailwind: composable primitives you can customize, extend, and ship without a heavy runtime. Open source; source is meant to be read and adapted.",
  "version": "0.1.0",
  "author": "Klaus Zahiragic <watzak>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamod-ch/kamod-ui.git"
  },
  "homepage": "https://kamod-ch.github.io/kamod-ui/",
  "keywords": [
    "ui",
    "preact",
    "css-framework",
    "typescript",
    "tailwind",
    "tailwind-css",
    "vite"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter @kamod-ui/core test",
    "test:demo": "pnpm --filter demo test",
    "doc:rewrite-imports": "node scripts/rewrite-kamod-doc-imports.mjs",
    "test:e2e": "pnpm --filter demo test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "dev": "pnpm --filter demo dev",
    "build:pages": "sh -c 'VITE_BASE_PATH=${VITE_BASE_PATH:-/kamod-ui/} pnpm run build'",
    "preview:pages": "pnpm run build:pages && pnpm --filter demo preview",
    "qa:themes": "pnpm --filter demo qa:themes",
    "mc:sync-inbox": "node scripts/mission-control-sync-inbox.mjs",
    "mc:sync-inbox:no-cloud-agent": "KAMOD_CURSOR_CLOUD_AGENT=0 node scripts/mission-control-sync-inbox.mjs",
    "mc:sync-inbox:cli-agent": "KAMOD_CURSOR_CLI_AGENT=1 KAMOD_CURSOR_CLOUD_AGENT=0 node scripts/mission-control-sync-inbox.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.12.4"
}
