    "lucide-preact": "^0.577.0",
    "preact": "^10.26.0",
    "preact-iso": "^2.11.1",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.2",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.2.2",
    "@types/prismjs": "^1.26.6",
    "oxfmt": "^0.43.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.3.8",
    "vite": "^8.0.6",
    "vitest": "^4.1.2"
  }
