    "lint": "tsc --noEmit",
    "qa:themes": "node ./scripts/theme-regression-check.mjs",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.6",
    "@kamod-ui/core": "workspace:*",
    "@tailwindcss/forms": "^0.5.10",
